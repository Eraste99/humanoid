{
  "uid": "router-queues",
  "title": "D6 — Router & Queues",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "style": "dark",
  "tags": ["bot", "router", "queues"],
  "refresh": "15s",
  "time": { "from": "now-6h", "to": "now" },
  "fiscalYearStartMonth": 1,
  "graphTooltip": 1,
  "timezone": "",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": { "selected": true, "text": "Prometheus", "value": "Prometheus" },
        "label": "Datasource"
      },
      {
        "name": "job",
        "type": "constant",
        "label": "Job (fixed)",
        "query": "arbitrage-bot",
        "current": { "selected": true, "text": "arbitrage-bot", "value": "arbitrage-bot" },
        "hide": 2
      }
    ]
  },
  "annotations": { "list": [] },
  "panels": [
    {
      "type": "row",
      "title": "Queue Depth",
      "id": 1,
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Router Queue Depth",
      "id": 2,
      "datasource": "$datasource",
      "targets": [
        {
          "expr": "router_queue_depth{job=\"$job\"}",
          "legendFormat": "{{queue}}",
          "refId": "A"
        }
      ],
      "gridPos": { "x": 0, "y": 1, "w": 8, "h": 4 }
    },
    {
      "type": "timeseries",
      "title": "Router Queue Depth by Exchange",
      "id": 3,
      "datasource": "$datasource",
      "targets": [
        {
          "expr": "router_queue_depth_by_ex{job=\"$job\"}",
          "legendFormat": "{{exchange}}/{{queue}}/{{shard}}",
          "refId": "A"
        }
      ],
      "gridPos": { "x": 8, "y": 1, "w": 8, "h": 4 }
    },
    {
      "type": "timeseries",
      "title": "Router Pair Queue Depth",
      "id": 4,
      "datasource": "$datasource",
      "targets": [
        {
          "expr": "router_pair_queue_depth{job=\"$job\"}",
          "legendFormat": "{{pair}}/{{tier}}",
          "refId": "A"
        }
      ],
      "gridPos": { "x": 16, "y": 1, "w": 8, "h": 4 }
    },
    {
      "type": "row",
      "title": "Drops & Latency",
      "id": 5,
      "gridPos": { "x": 0, "y": 5, "w": 24, "h": 1 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Router Dropped / sec",
      "id": 6,
      "datasource": "$datasource",
      "targets": [
        {
          "expr": "sum by (queue, reason) (rate(router_dropped_total{job=\"$job\"}[$__rate_interval]))",
          "legendFormat": "{{queue}}/{{reason}}",
          "refId": "A"
        }
      ],
      "gridPos": { "x": 0, "y": 6, "w": 8, "h": 4 }
    },
    {
      "type": "timeseries",
      "title": "Router→Scanner p50/p95 (ms)",
      "id": 7,
      "datasource": "$datasource",
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum(rate(router_to_scanner_ms_bucket{job=\"$job\"}[$__rate_interval])) by (le, route))",
          "legendFormat": "{{route}} p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(router_to_scanner_ms_bucket{job=\"$job\"}[$__rate_interval])) by (le, route))",
          "legendFormat": "{{route}} p95",
          "refId": "B"
        }
      ],
      "gridPos": { "x": 8, "y": 6, "w": 8, "h": 4 }
    },
    {
      "type": "timeseries",
      "title": "Router→Scanner Errors / sec",
      "id": 8,
      "datasource": "$datasource",
      "targets": [
        {
          "expr": "sum by (route, reason) (rate(router_to_scanner_errors_total{job=\"$job\"}[$__rate_interval]))",
          "legendFormat": "{{route}}/{{reason}}",
          "refId": "A"
        }
      ],
      "gridPos": { "x": 16, "y": 6, "w": 8, "h": 4 }
    },
    {
      "type": "row",
      "title": "Tier Pressure & Limits",
      "id": 9,
      "gridPos": { "x": 0, "y": 10, "w": 24, "h": 1 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "bargauge",
      "title": "Rotation Sizes",
      "id": 10,
      "datasource": "$datasource",
      "targets": [
        {
          "expr": "sc_rotation_primary_size{job=\"$job\"}",
          "legendFormat": "PRIMARY",
          "refId": "A"
        },
        {
          "expr": "sc_rotation_audition_size{job=\"$job\"}",
          "legendFormat": "AUDITION",
          "refId": "B"
        }
      ],
      "gridPos": { "x": 0, "y": 11, "w": 12, "h": 4 }
    },
    {
      "type": "timeseries",
      "title": "Out Queue MaxLen",
      "id": 11,
      "datasource": "$datasource",
      "targets": [
        {
          "expr": "router_cfg_out_queue_maxlen{job=\"$job\"}",
          "legendFormat": "{{kind}}",
          "refId": "A"
        }
      ],
      "gridPos": { "x": 12, "y": 11, "w": 12, "h": 4 }
    }
  ]
}
