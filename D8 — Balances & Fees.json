{
  "uid": "balances-fees",
  "title": "D8 — Balances & Fees",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "style": "dark",
  "tags": ["bot", "balances", "fees"],
  "refresh": "15s",
  "time": { "from": "now-6h", "to": "now" },
  "fiscalYearStartMonth": 1,
  "graphTooltip": 1,
  "timezone": "",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": { "selected": true, "text": "Prometheus", "value": "Prometheus" },
        "label": "Datasource"
      },
      {
        "name": "job",
        "type": "constant",
        "label": "Job (fixed)",
        "query": "arbitrage-bot",
        "current": { "selected": true, "text": "arbitrage-bot", "value": "arbitrage-bot" },
        "hide": 2
      }
    ]
  },
  "annotations": { "list": [] },
  "panels": [
    {
      "type": "row",
      "title": "Errors & Latency",
      "id": 1,
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "BF API Errors / sec",
      "id": 2,
      "datasource": "$datasource",
      "targets": [
        {
          "expr": "sum by (exchange, alias, reason) (rate(bf_api_errors_total{job=\"$job\"}[$__rate_interval]))",
          "legendFormat": "{{exchange}}/{{alias}}/{{reason}}",
          "refId": "A"
        }
      ],
      "gridPos": { "x": 0, "y": 1, "w": 8, "h": 4 }
    },
    {
      "type": "timeseries",
      "title": "BF API Latency p50/p95 (ms)",
      "id": 3,
      "datasource": "$datasource",
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum(rate(bf_api_latency_ms_bucket{job=\"$job\"}[$__rate_interval])) by (le, exchange, alias, endpoint))",
          "legendFormat": "{{exchange}}/{{alias}}/{{endpoint}} p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(bf_api_latency_ms_bucket{job=\"$job\"}[$__rate_interval])) by (le, exchange, alias, endpoint))",
          "legendFormat": "{{exchange}}/{{alias}}/{{endpoint}} p95",
          "refId": "B"
        }
      ],
      "gridPos": { "x": 8, "y": 1, "w": 8, "h": 4 }
    },
    {
      "type": "timeseries",
      "title": "BF HTTP Errors / sec",
      "id": 4,
      "datasource": "$datasource",
      "targets": [
        {
          "expr": "sum by (exchange, alias, endpoint) (rate(bf_http_errors_total{job=\"$job\"}[$__rate_interval]))",
          "legendFormat": "{{exchange}}/{{alias}}/{{endpoint}}",
          "refId": "A"
        }
      ],
      "gridPos": { "x": 16, "y": 1, "w": 8, "h": 4 }
    },
    {
      "type": "row",
      "title": "Balances",
      "id": 5,
      "gridPos": { "x": 0, "y": 5, "w": 24, "h": 1 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "BF Cache Age (s)",
      "id": 6,
      "datasource": "$datasource",
      "targets": [
        {
          "expr": "bf_cache_age_seconds{job=\"$job\"}",
          "legendFormat": "{{exchange}}/{{alias}}",
          "refId": "A"
        }
      ],
      "gridPos": { "x": 0, "y": 6, "w": 8, "h": 4 }
    },
    {
      "type": "stat",
      "title": "Balances Health State",
      "id": 7,
      "datasource": "$datasource",
      "targets": [
        {
          "expr": "bf_balances_health_state{job=\"$job\"}",
          "legendFormat": "{{exchange}}/{{alias}}",
          "refId": "A"
        }
      ],
      "gridPos": { "x": 8, "y": 6, "w": 8, "h": 4 }
    },
    {
      "type": "timeseries",
      "title": "Balances TTL (s)",
      "id": 8,
      "datasource": "$datasource",
      "targets": [
        {
          "expr": "bf_balances_ttl_normal_seconds{job=\"$job\"}",
          "legendFormat": "normal {{exchange}}",
          "refId": "A"
        },
        {
          "expr": "bf_balances_ttl_degraded_seconds{job=\"$job\"}",
          "legendFormat": "degraded {{exchange}}",
          "refId": "B"
        },
        {
          "expr": "bf_balances_ttl_block_seconds{job=\"$job\"}",
          "legendFormat": "block {{exchange}}",
          "refId": "C"
        }
      ],
      "gridPos": { "x": 16, "y": 6, "w": 8, "h": 4 }
    },
    {
      "type": "row",
      "title": "Fees",
      "id": 9,
      "gridPos": { "x": 0, "y": 10, "w": 24, "h": 1 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Fee Snapshot Age (s)",
      "id": 10,
      "datasource": "$datasource",
      "targets": [
        {
          "expr": "fee_snapshot_age_seconds{job=\"$job\"}",
          "legendFormat": "{{exchange}}/{{alias}}",
          "refId": "A"
        }
      ],
      "gridPos": { "x": 0, "y": 11, "w": 6, "h": 4 }
    },
    {
      "type": "timeseries",
      "title": "Fees Expected vs Realized (bps)",
      "id": 11,
      "datasource": "$datasource",
      "targets": [
        {
          "expr": "fees_expected_bps{job=\"$job\"}",
          "legendFormat": "expected {{exchange}}/{{alias}}",
          "refId": "A"
        },
        {
          "expr": "fees_realized_bps{job=\"$job\"}",
          "legendFormat": "realized {{exchange}}/{{alias}}",
          "refId": "B"
        }
      ],
      "gridPos": { "x": 6, "y": 11, "w": 9, "h": 4 }
    },
    {
      "type": "timeseries",
      "title": "Fee Mismatch / sec",
      "id": 12,
      "datasource": "$datasource",
      "targets": [
        {
          "expr": "sum by (exchange, alias, side) (rate(fee_mismatch_total{job=\"$job\"}[$__rate_interval]))",
          "legendFormat": "{{exchange}}/{{alias}}/{{side}}",
          "refId": "A"
        }
      ],
      "gridPos": { "x": 15, "y": 11, "w": 9, "h": 4 }
    }
  ]
}
