{
  "uid": "public-ws-health",
  "title": "D4 — Public WS Health",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "style": "dark",
  "tags": ["bot", "ws", "public"],
  "refresh": "10s",
  "time": { "from": "now-6h", "to": "now" },
  "fiscalYearStartMonth": 1,
  "graphTooltip": 1,
  "timezone": "",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": { "selected": true, "text": "Prometheus", "value": "Prometheus" },
        "label": "Datasource"
      },
      {
        "name": "job",
        "type": "constant",
        "label": "Job (fixed)",
        "query": "arbitrage-bot",
        "current": { "selected": true, "text": "arbitrage-bot", "value": "arbitrage-bot" },
        "hide": 2
      }
    ]
  },
  "annotations": { "list": [] },
  "panels": [
    {
      "type": "row",
      "title": "Connections & Staleness",
      "id": 1,
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "gauge",
      "title": "Connections Open (v2)",
      "id": 2,
      "datasource": "$datasource",
      "targets": [
        {
          "expr": "ws_public_connections_open_v2{job=\"$job\"}",
          "legendFormat": "{{exchange}}/{{region}}/{{deployment_mode}}",
          "refId": "A"
        }
      ],
      "gridPos": { "x": 0, "y": 1, "w": 8, "h": 4 }
    },
    {
      "type": "timeseries",
      "title": "Backoff (s)",
      "id": 3,
      "datasource": "$datasource",
      "targets": [
        {
          "expr": "ws_public_backoff_seconds_v2{job=\"$job\"}",
          "legendFormat": "{{exchange}}/{{region}}/{{deployment_mode}}",
          "refId": "A"
        }
      ],
      "gridPos": { "x": 8, "y": 1, "w": 8, "h": 4 }
    },
    {
      "type": "timeseries",
      "title": "Staleness (s)",
      "id": 4,
      "datasource": "$datasource",
      "targets": [
        {
          "expr": "ws_public_staleness_seconds{job=\"$job\"}",
          "legendFormat": "{{exchange}}/{{region}}/{{deployment_mode}}",
          "refId": "A"
        }
      ],
      "gridPos": { "x": 16, "y": 1, "w": 8, "h": 4 }
    },
    {
      "type": "row",
      "title": "Rates",
      "id": 5,
      "gridPos": { "x": 0, "y": 5, "w": 24, "h": 1 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Reconnects / sec (v2)",
      "id": 6,
      "datasource": "$datasource",
      "targets": [
        {
          "expr": "sum by (exchange, region, deployment_mode, reason) (rate(ws_public_reconnects_total_v2{job=\"$job\"}[$__rate_interval]))",
          "legendFormat": "{{exchange}}/{{region}}/{{deployment_mode}}/{{reason}}",
          "refId": "A"
        }
      ],
      "gridPos": { "x": 0, "y": 6, "w": 8, "h": 4 }
    },
    {
      "type": "timeseries",
      "title": "Dropped / sec (v2)",
      "id": 7,
      "datasource": "$datasource",
      "targets": [
        {
          "expr": "sum by (exchange, region, deployment_mode, reason) (rate(ws_public_dropped_total_v2{job=\"$job\"}[$__rate_interval]))",
          "legendFormat": "{{exchange}}/{{region}}/{{deployment_mode}}/{{reason}}",
          "refId": "A"
        }
      ],
      "gridPos": { "x": 8, "y": 6, "w": 8, "h": 4 }
    },
    {
      "type": "timeseries",
      "title": "Errors / sec (v2)",
      "id": 8,
      "datasource": "$datasource",
      "targets": [
        {
          "expr": "sum by (exchange, region, deployment_mode, reason) (rate(ws_public_errors_total_v2{job=\"$job\"}[$__rate_interval]))",
          "legendFormat": "{{exchange}}/{{region}}/{{deployment_mode}}/{{reason}}",
          "refId": "A"
        }
      ],
      "gridPos": { "x": 16, "y": 6, "w": 8, "h": 4 }
    },
    {
      "type": "timeseries",
      "title": "Events / sec (v2)",
      "id": 9,
      "datasource": "$datasource",
      "targets": [
        {
          "expr": "sum by (exchange, region, deployment_mode, stream) (rate(ws_public_events_total_v2{job=\"$job\"}[$__rate_interval]))",
          "legendFormat": "{{exchange}}/{{region}}/{{deployment_mode}}/{{stream}}",
          "refId": "A"
        }
      ],
      "gridPos": { "x": 0, "y": 10, "w": 24, "h": 4 }
    }
  ]
}