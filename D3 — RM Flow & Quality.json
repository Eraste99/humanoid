{
  "uid": "rm-flow-quality",
  "title": "D3 — RM Flow & Quality",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "style": "dark",
  "tags": ["bot", "rm", "quality"],
  "refresh": "15s",
  "time": { "from": "now-6h", "to": "now" },
  "fiscalYearStartMonth": 1,
  "graphTooltip": 1,
  "timezone": "",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": { "selected": true, "text": "Prometheus", "value": "Prometheus" },
        "label": "Datasource"
      },
      {
        "name": "job",
        "type": "constant",
        "label": "Job (fixed)",
        "query": "arbitrage-bot",
        "current": { "selected": true, "text": "arbitrage-bot", "value": "arbitrage-bot" },
        "hide": 2
      }
    ]
  },
  "annotations": { "list": [] },
  "panels": [
    {
      "type": "row",
      "title": "Decisions & Rejects",
      "id": 1,
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Final Decisions / sec",
      "id": 2,
      "datasource": "$datasource",
      "targets": [
        {
          "expr": "sum by (route) (rate(rm_final_decisions_total{job=\"$job\"}[$__rate_interval]))",
          "legendFormat": "{{route}}",
          "refId": "A"
        }
      ],
      "gridPos": { "x": 0, "y": 1, "w": 8, "h": 4 }
    },
    {
      "type": "timeseries",
      "title": "RM Decisions / sec",
      "id": 3,
      "datasource": "$datasource",
      "targets": [
        {
          "expr": "sum by (status) (rate(rm_decisions_total{job=\"$job\"}[$__rate_interval]))",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "gridPos": { "x": 8, "y": 1, "w": 8, "h": 4 }
    },
    {
      "type": "timeseries",
      "title": "RM Rejects / sec",
      "id": 4,
      "datasource": "$datasource",
      "targets": [
        {
          "expr": "sum by (reason) (rate(rm_reject_total{job=\"$job\"}[$__rate_interval]))",
          "legendFormat": "{{reason}}",
          "refId": "A"
        }
      ],
      "gridPos": { "x": 16, "y": 1, "w": 8, "h": 4 }
    },
    {
      "type": "row",
      "title": "Latency",
      "id": 5,
      "gridPos": { "x": 0, "y": 5, "w": 24, "h": 1 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "RM Decision Latency p50/p95 (ms)",
      "id": 6,
      "datasource": "$datasource",
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum(rate(rm_decision_ms_bucket{job=\"$job\"}[$__rate_interval])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(rm_decision_ms_bucket{job=\"$job\"}[$__rate_interval])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        }
      ],
      "gridPos": { "x": 0, "y": 6, "w": 12, "h": 4 }
    },
    {
      "type": "timeseries",
      "title": "RM Revalidate p95 (ms)",
      "id": 7,
      "datasource": "$datasource",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(rm_revalidate_ms_bucket{job=\"$job\"}[$__rate_interval])) by (le))",
          "legendFormat": "p95",
          "refId": "A"
        }
      ],
      "gridPos": { "x": 12, "y": 6, "w": 12, "h": 4 }
    },
    {
      "type": "row",
      "title": "State & Queues",
      "id": 8,
      "gridPos": { "x": 0, "y": 10, "w": 24, "h": 1 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "stat",
      "title": "RM Mode (one-hot)",
      "id": 9,
      "datasource": "$datasource",
      "targets": [
        {
          "expr": "rm_mode_current{job=\"$job\"}",
          "legendFormat": "{{mode}}",
          "refId": "A"
        }
      ],
      "gridPos": { "x": 0, "y": 11, "w": 6, "h": 4 }
    },
    {
      "type": "timeseries",
      "title": "RM Queue Depth",
      "id": 10,
      "datasource": "$datasource",
      "targets": [
        {
          "expr": "rm_queue_depth{job=\"$job\"}",
          "legendFormat": "{{stage}}",
          "refId": "A"
        }
      ],
      "gridPos": { "x": 6, "y": 11, "w": 9, "h": 4 }
    },
    {
      "type": "timeseries",
      "title": "RM Callback Inflight",
      "id": 11,
      "datasource": "$datasource",
      "targets": [
        {
          "expr": "rm_callback_inflight{job=\"$job\"}",
          "legendFormat": "{{cb_name}}",
          "refId": "A"
        }
      ],
      "gridPos": { "x": 15, "y": 11, "w": 9, "h": 4 }
    },
    {
      "type": "row",
      "title": "Rebalancing & Operations",
      "id": 12,
      "gridPos": { "x": 0, "y": 15, "w": 24, "h": 1 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Rebalancing Ops / sec",
      "id": 13,
      "datasource": "$datasource",
      "targets": [
        {
          "expr": "sum by (type) (rate(rebal_operations_total{job=\"$job\"}[$__rate_interval]))",
          "legendFormat": "{{type}}",
          "refId": "A"
        }
      ],
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 4 }
    },
    {
      "type": "timeseries",
      "title": "Rebalancing Plan Build Latency (ms)",
      "id": 14,
      "datasource": "$datasource",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(rebal_plan_build_ms_bucket{job=\"$job\"}[$__rate_interval])) by (le))",
          "legendFormat": "p95",
          "refId": "A"
        }
      ],
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 4 }
    },
    {
      "type": "row",
      "title": "Unified Quality & Robustness",
      "id": 15,
      "gridPos": { "x": 0, "y": 20, "w": 24, "h": 1 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Realized Edge Net (bps)",
      "id": 16,
      "datasource": "$datasource",
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum by (branch, le) (rate(edge_net_bps_hist_bucket{job=\"$job\"}[$__rate_interval])))",
          "legendFormat": "{{branch}} p50",
          "refId": "A"
        }
      ],
      "gridPos": { "x": 0, "y": 21, "w": 8, "h": 4 }
    },
    {
      "type": "timeseries",
      "title": "Unified Rejects / sec",
      "id": 17,
      "datasource": "$datasource",
      "targets": [
        {
          "expr": "sum by (layer, reason) (rate(reject_total{job=\"$job\"}[$__rate_interval]))",
          "legendFormat": "{{layer}}: {{reason}}",
          "refId": "A"
        }
      ],
      "gridPos": { "x": 8, "y": 21, "w": 8, "h": 4 }
    },
    {
      "type": "timeseries",
      "title": "Execution Aborts / sec",
      "id": 18,
      "datasource": "$datasource",
      "targets": [
        {
          "expr": "sum by (branch, reason) (rate(abort_total{job=\"$job\"}[$__rate_interval]))",
          "legendFormat": "{{branch}}: {{reason}}",
          "refId": "A"
        }
      ],
      "gridPos": { "x": 16, "y": 21, "w": 8, "h": 4 }
    }
  ]
}
